{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automergeType": "branch",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/.*Dockerfile/", "/workflows/.*\\.yaml/"],
      "matchStrings": [
        "datasource=(?<datasource>.*?) depName=(?<depName>.*?)( versioning=(?<versioning>.*?))?\\s(ENV|ARG) .*?_VERSION=(?<currentValue>.*)\\s",
        "datasource=(?<datasource>.*?) depName=(?<depName>.*?)( versioning=(?<versioning>.*?))?\\s.*?_VERSION=(?<currentValue>.*)\\s"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    }
  ],
  "extends": ["config:recommended"],
  "minimumReleaseAge": "14 days",
  "packageRules": [
    {
      "matchManagers": ["npm", "dockerfile"],
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "labels": ["bump:patch"]
    },
    {
      "matchManagers": ["npm", "dockerfile"],
      "matchUpdateTypes": ["minor"],
      "automerge": true,
      "labels": ["bump:minor"]
    },
    {
      "matchManagers": ["npm", "dockerfile"],
      "matchUpdateTypes": ["major"],
      "labels": ["bump:major"]
    },
    {
      "matchManagers": ["github-actions"],
      "labels": ["dependency"]
    }
  ],
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "rebaseWhen": "conflicted",
  "separateMinorPatch": true
}
